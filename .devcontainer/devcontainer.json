{
  "name": "Categorical X",
  "features": {
    // Substrate / peers toolchain (Rust + Lean + wasm)
    "ghcr.io/devcontainers/features/rust:1": {},
    "ghcr.io/guiyomh/features/just:0": {},
    "ghcr.io/lumenpink/devcontainer-features/wasm-pack:0": {},
    // Documentation pipeline runtimes (docs/ — arc42+C4 / OPM / ISO 15288).
    // JDK 21 is provided via apt in postCreate + pinned on PATH below
    // (the pipeline pins JDK 21; the base image's default JDK is newer).
    "ghcr.io/devcontainers/features/ruby:1": { "version": "3.3" },
    "ghcr.io/devcontainers/features/node:1": { "version": "lts" },
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "anthropic.claude-code",
        "leanprover.lean4",
        "asciidoctor.asciidoctor-vscode"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "[rust]": {
          "editor.defaultFormatter": "rust-lang.rust-analyzer"
        },
        "rust-analyzer.check.command": "clippy",
        "rust-analyzer.procMacro.enable": true,
        "rust-analyzer.cargo.allFeatures": true,
        "search.exclude": {
          "**/target": true,
          "**/docs/vendor": true
        },
        "files.watcherExclude": {
          "**/target/**": true,
          "**/docs/vendor/**": true
        }
      }
    }
  },
  "remoteEnv": {
    // The doc pipeline (docs/scripts/install-tools.sh) pins JDK 21. openjdk-21
    // is installed in postCreate; pin JAVA_HOME and put it first on PATH so it
    // takes precedence over the base image's default (newer) JDK.
    "JAVA_HOME": "/usr/lib/jvm/java-1.21.0-openjdk-amd64",
    "PATH": "/usr/lib/jvm/java-1.21.0-openjdk-amd64/bin:/home/codespace/.elan/bin:/home/codespace/.cargo/bin:${containerEnv:PATH}"
  },
  // Doc-pipeline prereqs: JDK 21 (pinned above), cmake/build-essential/pkg-config
  // (cmark-gfm is built from source), graphviz (OPL->SVG); plus the Lean toolchain.
  // The heavy doc-build binaries (structurizr.war, pandoc, cmark-gfm, Playwright
  // deps, submodules) are provisioned on demand by docs/scripts/install-tools.sh.
  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y --no-install-recommends openjdk-21-jdk cmake build-essential pkg-config graphviz && curl https://elan.lean-lang.org/elan-init.sh -sSf | sh -s -- -y --default-toolchain none"
}
