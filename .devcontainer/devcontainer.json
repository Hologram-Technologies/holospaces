{
  "name": "holospaces",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",
  "features": {
    // Substrate / peers toolchain (Rust + Lean + wasm)
    "ghcr.io/devcontainers/features/rust:1": {},
    "ghcr.io/guiyomh/features/just:0": {},
    "ghcr.io/lumenpink/devcontainer-features/wasm-pack:0": {},
    // Documentation pipeline runtimes
    "ghcr.io/devcontainers/features/ruby:1": {
      "version": "3.3"
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts"
    },
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/dirien/devcontainer-feature-codex/codex:0": {},
    "ghcr.io/anthropics/devcontainer-features/claude-code:1.0": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "vadimcn.vscode-lldb",
        "anthropic.claude-code",
        "leanprover.lean4",
        "asciidoctor.asciidoctor-vscode"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "[rust]": {
          "editor.defaultFormatter": "rust-lang.rust-analyzer",
        },
        "rust-analyzer.check.command": "clippy",
        "rust-analyzer.procMacro.enable": true,
        "rust-analyzer.cargo.allFeatures": true,
        "search.exclude": {
          "**/target": true,
          "**/docs/vendor": true,
        },
        "files.watcherExclude": {
          "**/target/**": true,
          "**/docs/vendor/**": true,
        },
      },
    },
  },
  "mounts": [
    "source=${localEnv:HOME}/.claude,target=/home/node/.claude,type=bind,consistency=cached",
  ],
  "remoteEnv": {
    "JAVA_HOME": "/usr/lib/jvm/java-1.21.0-openjdk-amd64",
    "PATH": "/usr/lib/jvm/java-1.21.0-openjdk-amd64/bin:/home/vscode/.elan/bin:/home/vscode/.cargo/bin:${containerEnv:PATH}",
    "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}",
    "OPENAI_API_KEY": "${localEnv:OPENAI_API_KEY}",
  },
  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y --no-install-recommends openjdk-21-jdk cmake build-essential pkg-config graphviz curl ca-certificates just && curl https://elan.lean-lang.org/elan-init.sh -sSf | sh -s -- -y --default-toolchain none",
}